#!/bin/bash
set -euo pipefail

# Usage: claude-playwright-headless [project-dir] [claude-args...]
#
# First non-flag argument is the project directory (defaults to .).
# All remaining arguments are forwarded to claude inside the container.

if [ $# -gt 0 ] && [[ "$1" != -* ]]; then
  PROJECT_DIR="$(realpath "$1")"
  shift
else
  PROJECT_DIR="$(realpath .)"
fi

if [ ! -d "$PROJECT_DIR" ]; then
  echo "Error: $PROJECT_DIR is not a directory"
  exit 1
fi

# Resolve claude binary path
CLAUDE_BINARY="$(readlink -f "$HOME/.local/bin/claude")"

# Allocate TTY/stdin only when connected to a terminal
DOCKER_TTY=""
[ -t 0 ] && DOCKER_TTY="-i"
[ -t 1 ] && DOCKER_TTY="$DOCKER_TTY -t"

# Sandbox MCP config (Playwright etc.)
SANDBOX_DIR="$(dirname "$(readlink -f "$0")")"

docker run --rm --shm-size=1g $DOCKER_TTY \
  -v "$PROJECT_DIR":/workspace \
  -v "$HOME/.claude":/home/dev/.claude \
  -v "$HOME/.claude.json":/home/dev/.claude.json \
  -v "$HOME/CLAUDE.md":/home/dev/CLAUDE.md:ro \
  -v "$CLAUDE_BINARY":/home/dev/.local/bin/claude:ro \
  -v "$SANDBOX_DIR/mcp.json":/workspace/sandbox-mcp.json:ro \
  claude-playwright-headless "$@" --mcp-config /workspace/sandbox-mcp.json
